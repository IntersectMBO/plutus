(let (rec)
  (termbind (strict) (vardecl even (fun (con integer) (con bool)))
    (lam n (con integer)
      [ {(builtin ifThenElse) (fun (con unit) (con bool))}
          [(builtin equalsInteger) n (con integer 0)]
          (lam u (con unit) (con bool True))
          (lam u (con unit)
            [odd [(builtin subtractInteger) n (con integer 1)]])
          (con unit ())
      ]))
  (termbind (strict) (vardecl odd (fun (con integer) (con bool)))
    (lam m (con integer)
      [ {(builtin ifThenElse) (fun (con unit) (con bool))}
          [(builtin equalsInteger) m (con integer 0)]
          (lam u (con unit) (con bool False))
          (lam u (con unit)
            [even [(builtin subtractInteger) m (con integer 1)]])
          (con unit ())
      ]))
  (let (nonrec)
    (termbind (strict) (vardecl x (fun (con integer) (con bool)))
      even)
    odd))
