letrec
  !even : integer -> bool
    = \(n : integer) ->
        ifThenElse
          {unit -> bool}
          (equalsInteger n 0)
          (\(u : unit) -> True)
          (\(u : unit) ->
             (\(m : integer) ->
                ifThenElse
                  {unit -> bool}
                  (equalsInteger m 0)
                  (\(u : unit) -> False)
                  (\(u : unit) -> even (subtractInteger m 1))
                  ())
               (subtractInteger n 1))
          ()
in
even