program
  1.1.0
  ((/\a b ->
      \(f : (a -> b) -> a -> b) ->
        (\(s : (\a -> ifix (\(self :: * -> *) a -> self a -> a) a) (a -> b)) ->
           unwrap s s)
          (iwrap
             (\(self :: * -> *) a -> self a -> a)
             (a -> b)
             (\(s :
                  (\a -> ifix (\(self :: * -> *) a -> self a -> a) a)
                    (a -> b)) ->
                f (\(x : a) -> unwrap s s x))))
     {all a. a -> a}
     {all a. a -> a}
     (\(x : (all a. a -> a) -> (all a. a -> a)) (arg : all a. a -> a) ->
        /\a -> \(z : a) -> x (/\a -> \(x : a) -> x) {a} z)
     (/\a -> \(x : a) -> x))