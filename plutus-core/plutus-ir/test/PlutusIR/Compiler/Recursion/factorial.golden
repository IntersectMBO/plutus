program
  1.1.0
  ((\forced ->
      (\s -> s s 5)
        (\s i ->
           case
             (constr 0
                [ (equalsInteger 0 i)
                , (\u -> 1)
                , (\u ->
                     multiplyInteger i ((\x -> s s x) (subtractInteger i 1)))
                , () ])
             [forced]))
     (force ifThenElse))