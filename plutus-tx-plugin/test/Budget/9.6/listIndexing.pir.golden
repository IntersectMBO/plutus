let
  data Bool | Bool_match where
    True : Bool
    False : Bool
in
letrec
  data (List :: * -> *) a | List_match where
    Nil : List a
    Cons : a -> List a -> List a
in
let
  data Unit | Unit_match where
    Unit : Unit
  !traceError : all a. string -> a
    = /\a ->
        \(str : string) -> let !x : Unit = trace {Unit} str Unit in error {a}
in
letrec
  !go : integer -> List data -> data
    = \(ds : integer) (ds : List data) ->
        List_match
          {data}
          ds
          {all dead. data}
          (/\dead -> traceError {data} "PT7")
          (\(x : data) (xs : List data) ->
             /\dead ->
               Bool_match
                 (case Bool (equalsInteger 0 ds) [False, True])
                 {all dead. data}
                 (/\dead -> x)
                 (/\dead -> go (subtractInteger ds 1) xs)
                 {all dead. dead})
          {all dead. dead}
in
\(xs : List data) ->
  Bool_match
    (case Bool False [False, True])
    {all dead. data}
    (/\dead -> traceError {data} "PT6")
    (/\dead -> go 5 xs)
    {all dead. dead}